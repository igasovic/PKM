    {
      "id": "f8467a91-6e7f-4d6e-b5ae-96ee674c8d97",
      "name": "Format",
      "parameters": {
        "jsCode": "const raw = $json.stdout ?? '{}';\nlet s = {};\ntry { s = JSON.parse(raw); } catch (e) { s = {}; }\n\nconst get = (k) => s[k] ?? { status: 'missing', ts: '-', rc: '-', host: '-', cmd: '' };\n\nconst daily  = get('pkm_backup_daily');\nconst weekly = get('pkm_backup_weekly');\nconst monthly= get('pkm_backup_monthly');\nconst rotate = get('pkm_backup_rotate');\n\nconst today = new Date().toISOString().slice(0,10);\n\nconst msg =\n`📊 PKM Cron Summary (latest)\ndate: ${today} (America/Chicago)\n\nDaily:   ${daily.status}  rc=${daily.rc}  ts=${daily.ts}\nWeekly:  ${weekly.status} rc=${weekly.rc} ts=${weekly.ts}\nMonthly: ${monthly.status} rc=${monthly.rc} ts=${monthly.ts}\nRotate:  ${rotate.status} rc=${rotate.rc} ts=${rotate.ts}\n`;\n\nreturn [{ summary: msg }];\n"
      },
      "position": [
        96,
        -752
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "id": "020b27e4-71d9-4989-848b-793b0fb8bf1b",
      "name": "Parse",
      "parameters": {
        "jsCode": "const b = $json.body || $json;\n\nconst job = String(b.job ?? '');\nconst host = String(b.host ?? '');\nconst ts = String(b.ts ?? '');\nconst rc = String(b.rc ?? '');\nconst cmd = String(b.cmd ?? '');\nconst status = String(b.status ?? (Number(b.rc ?? 0) === 0 ? 'ok' : 'fail'));\n\nconst icon = status === 'ok' ? '✅' : '❌';\n\n// Escape for Telegram MarkdownV2\nconst esc = (s) => String(s).replace(/[_*\\[\\]()~`>#+\\-=|{}.!\\\\]/g, '\\\\$&');\n\nconst msg =\n`*${icon} CRON: ${esc(status)}*\\n` +\n`job: ${esc(job)}\\n` +\n`host: ${esc(host)}\\n` +\n`ts: ${esc(ts)}\\n` +\n`rc: ${esc(rc)}\\n` +\n`cmd: \\`${esc(cmd)}\\``;\n\nreturn [{ telegram_text: msg }];\n"
      },
      "position": [
        96,
        -336
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
