      "id": "a4c32ff8-1774-45dd-bd8c-5594272a7e11",
      "name": "Normalize",
      "parameters": {
        "jsCode": "// n8n Webhook payload lives under $json.body\nconst b = $json.body || {};\n\nreturn [\n  {\n    job: String(b.job ?? 'unknown'),\n    host: String(b.host ?? 'unknown'),\n    ts: String(b.ts ?? new Date().toISOString()),\n    rc: Number.isFinite(b.rc) ? b.rc : Number(b.rc ?? 0),\n    cmd: String(b.cmd ?? ''),\n    status: (Number(b.rc ?? 0) === 0) ? 'ok' : 'fail',\n  }\n];"
      },
      "position": [
        -128,
        -432
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "credentials": {
        "sshPassword": {
          "id": "9D3Ebf2kKfkEuCDJ",
          "name": "SSH Password account"
        }
      },
      "id": "12c6f12e-3181-4d21-9de0-0e80ef8f24d4",
      "name": "Execute a command",
      "parameters": {
        "command": "=bash -lc '\nset -euo pipefail\n\nFILE=\"/home/igasovic/backup/postgres/cron_status.json\"\nLOCK=\"/tmp/cron_status.lock\"\n\nJOB=\"{{ $json.job }}\"\nSTATUS=\"{{ $json.status }}\"\nTS=\"{{ $json.ts }}\"\nRC=\"{{ $json.rc }}\"\nHOST=\"{{ $json.host }}\"\nCMD=\"{{ $json.cmd }}\"\n\n# serialize updates so parallel webhooks don’t race\nexec 9>\"$LOCK\"\nflock -x 9\n\nTMP=\"$(mktemp)\"\nif [ -f \"$FILE\" ]; then\n  cat \"$FILE\" > \"$TMP\"\nelse\n  echo \"{}\" > \"$TMP\"\nfi\n\njq --arg job \"$JOB\" \\\n   --arg status \"$STATUS\" \\\n   --arg ts \"$TS\" \\\n   --arg host \"$HOST\" \\\n   --arg cmd \"$CMD\" \\\n   --argjson rc \"$RC\" \\\n   '\"'\"'.[$job] = {status:$status, ts:$ts, rc:$rc, host:$host, cmd:$cmd}'\"'\"' \\\n   \"$TMP\" > \"${TMP}.out\"\n\nmv \"${TMP}.out\" \"$FILE\"\nrm -f \"$TMP\"\n'\n"
      },
