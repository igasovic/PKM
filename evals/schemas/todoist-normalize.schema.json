{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pkm.local/evals/schemas/todoist-normalize.schema.json",
  "title": "Todoist Normalize Fixture",
  "type": "object",
  "additionalProperties": false,
  "required": ["case_id", "name", "bucket", "corpus_group", "failure_tags", "input", "expect"],
  "properties": {
    "case_id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "bucket": {
      "type": "string",
      "enum": ["project", "next_action", "micro_task", "follow_up", "vague_note", "unknown"]
    },
    "corpus_group": {
      "type": "string",
      "enum": ["gold_only", "prompt_examples", "eval_core"]
    },
    "failure_tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_title", "project_key"],
      "properties": {
        "raw_title": { "type": "string", "minLength": 1 },
        "raw_description": { "type": ["string", "null"] },
        "project_key": { "type": "string", "minLength": 1 },
        "todoist_section_name": { "type": ["string", "null"] },
        "lifecycle_status": {
          "type": "string",
          "enum": ["open", "waiting", "closed"]
        },
        "has_subtasks": { "type": "boolean" },
        "explicit_project_signal": { "type": "boolean" }
      }
    },
    "expect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_shape", "normalized_title_en"],
      "properties": {
        "task_shape": {
          "type": "string",
          "enum": ["project", "next_action", "micro_task", "follow_up", "vague_note", "unknown"]
        },
        "normalized_title_en": { "type": "string", "minLength": 1 },
        "suggested_next_action": { "type": ["string", "null"] }
      }
    }
  }
}
