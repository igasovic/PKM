#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

usage() {
  local exit_code="${1:-2}"
  cat >&2 <<'EOF'
Usage: bootstrapcfg [--skip-n8n] [--surface <surface> ...]

Description:
  Import runtime config into repo for multiple surfaces by calling importcfg.

Options:
  --surface <surface>    surface to import (repeatable)
  --skip-n8n             skip n8n from default surface set
  --include-n8n          compatibility alias (n8n is included by default)
EOF
  echo "Supported surfaces:" >&2
  print_supported_surfaces >&2
  exit "$exit_code"
}

include_n8n=1
declare -a requested_surfaces=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --surface)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for --surface" >&2
        usage 2
      fi
      requested_surfaces+=("$2")
      shift 2
      ;;
    --include-n8n)
      include_n8n=1
      shift
      ;;
    --skip-n8n)
      include_n8n=0
      shift
      ;;
    -h|--help)
      usage 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage 2
      ;;
  esac
done

if [[ ${#requested_surfaces[@]} -eq 0 ]]; then
  requested_surfaces=(docker litellm postgres cloudflared)
  if [[ "$include_n8n" -eq 1 ]]; then
    requested_surfaces+=(n8n)
  fi
fi

declare -a surfaces=()
surface=""
for surface in "${requested_surfaces[@]}"; do
  if ! is_supported_surface "$surface"; then
    echo "Unknown surface: $surface" >&2
    echo "Supported surfaces:" >&2
    print_supported_surfaces >&2
    exit 2
  fi
  if [[ "$surface" == "backend" ]]; then
    echo "bootstrapcfg does not support backend import (no runtime-to-repo import path)." >&2
    exit 2
  fi
  if ! array_contains "$surface" "${surfaces[@]-}"; then
    surfaces+=("$surface")
  fi
done

if [[ ${#surfaces[@]} -eq 0 ]]; then
  echo "No surfaces selected." >&2
  exit 2
fi

total="${#surfaces[@]}"
idx=0
for surface in "${surfaces[@]}"; do
  idx=$(( idx + 1 ))
  echo "[$idx/$total] importcfg $surface"
  "$SCRIPT_DIR/importcfg" "$surface"
done

echo "Bootstrap import complete."
