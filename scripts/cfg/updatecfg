#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

usage() {
  local exit_code="${1:-2}"
  cat >&2 <<EOF
Usage: updatecfg <surface> [--push|--pull]

Options:
  --push               repo -> runtime (default)
  --pull               runtime -> repo
EOF
  echo "Supported surfaces:" >&2
  print_supported_surfaces >&2
  exit "$exit_code"
}

mode="push"
positionals=()
seen_push=0
seen_pull=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --push)
      mode="push"
      seen_push=1
      shift
      ;;
    --pull)
      mode="pull"
      seen_pull=1
      shift
      ;;
    -h|--help)
      usage 0
      ;;
    *)
      if [[ "$1" == --* ]]; then
        echo "Unknown option: $1" >&2
        usage 2
      fi
      positionals+=("$1")
      shift
      ;;
  esac
done

if [[ "$seen_push" -eq 1 && "$seen_pull" -eq 1 ]]; then
  echo "Options --push and --pull are mutually exclusive." >&2
  usage 2
fi

if require_single_surface_arg "updatecfg" "${positionals[@]}"; then
  :
else
  rc=$?
  exit "$rc"
fi

surface="${positionals[0]}"

reset_update_state
run_surface_update "$surface" "$mode"
print_update_report

update_exit_code
rc=$?
exit "$rc"
