#!/usr/bin/env bash
set -euo pipefail

STACK_DIR="/home/igasovic/stack"

SERVICE="${1:-}"
if [[ -z "$SERVICE" ]]; then
  echo "Usage: recreate <service>" >&2
  exit 1
fi

cd "$STACK_DIR"
docker compose up -d --no-deps --force-recreate "$SERVICE"

if [[ "$SERVICE" == "n8n" ]]; then
  echo "Waiting for n8n CLI to become ready..."
  for i in $(seq 1 30); do
    if docker exec -u node n8n n8n --help >/dev/null 2>&1; then
      echo "n8n CLI is ready."
      exit 0
    fi
    sleep 2
  done
  echo "n8n did not become ready in time." >&2
  exit 1
fi
