  },
  {
    "name": "two-word meeting tomorrow create",
    "input": { "text": "meeting tomorrow" },
    "expect": { "route": "calendar_create" }
  },
  {
    "name": "explicit create event avoids ambiguous",
    "input": { "text": "create family event tomorrow at 7:00p" },
