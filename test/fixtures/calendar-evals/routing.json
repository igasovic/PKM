    "expect": { "route": "pkm_capture" }
  },
  {
    "name": "short temporal query",
    "input": { "text": "tomorrow" },
    "expect": { "route": "calendar_query" }
  },
  {
    "name": "two-word events tomorrow query",
    "input": { "text": "events tomorrow" },
    "expect": { "route": "calendar_query" }
  },
  {
    "name": "two-word calendar today query",
    "input": { "text": "calendar today" },
    "expect": { "route": "calendar_query" }
  },
  {
    "name": "two-word plan friday stays pkm",
    "input": { "text": "plan friday" },
    "expect": { "route": "pkm_capture" }
  },
  {
    "name": "two-word events monday query",
    "input": { "text": "events monday" },
    "expect": { "route": "calendar_query" }
  },
  {
    "name": "two-word calendar friday query",
    "input": { "text": "calendar friday" },
    "expect": { "route": "calendar_query" }
  },
  {
    "name": "two-word plans today query",
