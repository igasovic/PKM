    {
      "id": "54d6fd6b-5f26-4a56-a90d-4cdfa41cd0d5",
      "name": "Route Telegram Capture Mode",
      "parameters": {
        "jsCode": "'use strict';\n\nconst inputText = String($json.raw_text || ($json.message && ($json.message.text || $json.message.caption)) || '').trim();\nconst URL_RE = /(https?:\\/\\/[^\\s<>()]+|www\\.[^\\s<>()]+)/ig;\nconst matches = inputText.match(URL_RE) || [];\nconst seen = new Set();\nconst urls = matches\n  .map((u) => {\n    let v = String(u || '').trim();\n    while (/[)\\],.?!:;\"'»]+$/.test(v)) v = v.replace(/[)\\],.?!:;\"'»]+$/, '');\n    if (/^www\\./i.test(v)) v = `https://${v}`;\n    return v;\n  })\n  .filter(Boolean)\n  .filter((u) => {\n    const k = u.toLowerCase();\n    if (seen.has(k)) return false;\n    seen.add(k);\n    return true;\n  });\n\nconst textWithoutUrls = inputText\n  .replace(URL_RE, ' ')\n  .replace(/[\\t\\r\\n,;|\\u2022]+/g, ' ')\n  .replace(/\\s+/g, ' ')\n  .trim();\n\nconst residue = textWithoutUrls\n  .replace(/[()\\[\\]{}<>0-9.\\-_:]/g, '')\n  .trim();\n\nconst hasUrls = urls.length > 0;\nconst isUrlOnly = hasUrls && residue.length === 0;\nconst mode = isUrlOnly ? 'url' : 'thought';\nconst normalizedThoughtText = hasUrls && !isUrlOnly ? textWithoutUrls : inputText;\n\nreturn [{\n  json: {\n    ...$json,\n    raw_text: normalizedThoughtText,\n    raw_text_original: inputText,\n    telegram_capture_mode: mode,\n    telegram_url_count: urls.length,\n    telegram_urls: urls,\n    telegram_mode_error: null\n  },\n}];"
      },
