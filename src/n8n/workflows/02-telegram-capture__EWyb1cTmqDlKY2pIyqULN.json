        "jsCode": "'use strict';\n\nconst urls = Array.isArray($json.telegram_urls) ? $json.telegram_urls.filter(Boolean) : [];\nif (!urls.length) return [];\n\nconst source = {\n  system: 'telegram',\n  chat_id: $json.telegram_chat_id || ($json.message && $json.message.chat && $json.message.chat.id) || null,\n  message_id: $json.telegram_message_id || ($json.message && $json.message.message_id) || null,\n  user_id: $json.telegram_user_id || ($json.message && $json.message.from && $json.message.from.id) || null,\n};\n\nreturn urls.map((url, idx) => {\n  const u = String(url);\n  return {\n    json: {\n      ...$json,\n      raw_text: u,\n      url: u,\n      url_canonical: u,\n      content_type: 'newsletter',\n      source,\n      telegram_url_index: idx,\n    },\n  };\n});"
