ted_at\",\n      \"source\",\n      \"intent\",\n      \"content_type\",\n      \"title\",\n      \"author\",\n      \"clean_text\",\n      \"metadata\",\n      \"COALESCE(char_length(clean_text), 0) AS clean_len\"\n    ]\n  };\n\n  return body;\n})()) }}\n",
